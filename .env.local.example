# ============================================
# SUPABASE Configuration
# ============================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ============================================
# OpenAI Configuration
# ============================================
OPENAI_API_KEY=sk-your-api-key-here

# ============================================
# Environment
# ============================================
NODE_ENV=production
NEXT_PUBLIC_SITE_URL=https://proximopasso.com.br

# ============================================
# Email Service (SendGrid)
# ============================================
SENDGRID_API_KEY=SG.your-api-key-here
SENDGRID_FROM_EMAIL=noreply@proximopasso.com.br

# ============================================
# Analytics
# ============================================
NEXT_PUBLIC_POSTHOG_KEY=your-posthog-key-here
SENTRY_AUTH_TOKEN=your-sentry-token-here

# ============================================
# Vercel KV (Redis)
# ============================================
KV_URL=redis://your-kv-url
KV_REST_API_URL=https://your-kv-rest-url
KV_REST_API_TOKEN=your-kv-token
